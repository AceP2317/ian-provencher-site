---
/**
 * PipelineFlow — a mini "living architecture": a labeled signal path with
 * traveling-dot pulses on each edge and firing nodes. Pure SVG/CSS, ZERO
 * client JS; decorative (aria-hidden — the surrounding prose carries the meaning).
 * Renders BOTH orientations and lets a CSS breakpoint pick: left→right ≥ md,
 * a top→down stack below md (phones — where the wide SVG used to clip).
 * Motion via the shared .pf-syn/.pf-fire classes in global.css — static under
 * reduced motion. Amber-themed port of appliediqsolutions' DeskSchematic.
 *
 * Usage:
 *   <PipelineFlow
 *     label="How a publish reaches the site"
 *     stages={[
 *       { name: 'export', note: 'private → public-safe' },
 *       { name: 'gate', note: 'never ships red', lit: true },
 *       { name: 'commit', note: 'reviewable diff' },
 *       { name: 'deploy', note: 'live in ~1 min', lit: true },
 *     ]}
 *   />
 */
export interface FlowStage {
  /** Short stage name (rendered uppercase). */
  name: string;
  /** One-line note under the stage. */
  note?: string;
  /** Highlight this node (a brighter, cyan-firing dot). */
  lit?: boolean;
}
interface Props {
  stages: FlowStage[];
  /** Optional caption above the diagram. */
  label?: string;
  class?: string;
}
const { stages, label, class: className } = Astro.props;

/* Colors come from the design tokens ONLY — never a literal hex (CLAUDE.md). Delivered
   as `style="fill: var(…)"` rather than a `fill="…"` presentation attribute: var() is
   reliable in a style attribute across browsers, and inline style beats the .pf-syn /
   .pf-fire class rules besides. Same approach as Wordmark.astro. Re-skinning the site
   = swapping the @theme block; this diagram follows. */
const C = {
  accent: 'var(--color-accent)',    // amber (primary)
  accent2: 'var(--color-accent-2)', // lighter amber
  cyan: 'var(--color-cyan)',
  cyan2: 'var(--color-cyan-2)',
  line: 'var(--color-line)',
  label: 'var(--color-label)',
  faint: 'var(--color-ink-faint)',
  surface: 'var(--color-surface)',
};

const n = Math.max(stages.length, 1);

const link = (x1: number, y1: number, x2: number, y2: number, hot: boolean) =>
  `<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" style="stroke: ${hot ? C.accent : C.line}" stroke-width="${hot ? 1.4 : 1.2}" opacity="${hot ? 0.55 : 0.9}"/>`;

const pulse = (x1: number, y1: number, x2: number, y2: number, delay: number, color: string, w: number) =>
  `<line class="pf-syn" x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" pathLength="100" stroke-width="${w}" style="stroke: ${color}; animation-delay:${delay}s"/>`;

const node = (x: number, y: number, lit: boolean) =>
  `<circle cx="${x}" cy="${y}" r="12" style="fill: ${C.surface}; stroke: ${lit ? C.accent2 : C.accent}" stroke-width="1.5"/>` +
  `<circle ${lit ? 'class="pf-fire" ' : ''}cx="${x}" cy="${y}" r="3.2" style="fill: ${lit ? C.cyan : C.accent2}"/>`;

const tag = (x: number, y: number, t: string, anchor = 'middle') =>
  `<text x="${x}" y="${y}" text-anchor="${anchor}" font-family="IBM Plex Mono, ui-monospace, monospace" font-size="13" font-weight="600" letter-spacing="2" style="fill: ${C.label}">${t.toUpperCase()}</text>`;

const sub = (x: number, y: number, t: string, anchor = 'middle') =>
  `<text x="${x}" y="${y}" text-anchor="${anchor}" font-family="IBM Plex Mono, ui-monospace, monospace" font-size="10.5" letter-spacing="0.8" style="fill: ${C.faint}">${t}</text>`;

const esc = (s: string) => String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

/* Horizontal (≥ md): nodes on a row, labels centered beneath. */
const PAD = 80, GAP = 208, Y = 78;
const W = PAD * 2 + (n - 1) * GAP;
const xOf = (i: number) => PAD + i * GAP;

function schematic() {
  let s = '';
  for (let i = 0; i < n - 1; i++) s += link(xOf(i), Y, xOf(i + 1), Y, i >= 1);
  for (let i = 0; i < n - 1; i++) {
    s += pulse(xOf(i), Y, xOf(i + 1), Y, -0.55 * i - 0.4, i % 2 ? C.cyan2 : C.cyan, i % 2 ? 3.4 : 4);
  }
  for (let i = 0; i < n; i++) s += node(xOf(i), Y, !!stages[i]?.lit);
  for (let i = 0; i < n; i++) {
    s += tag(xOf(i), Y + 39, esc(stages[i].name));
    if (stages[i].note) s += sub(xOf(i), Y + 56, esc(stages[i].note!));
  }
  return `<svg viewBox="0 0 ${W} 150" xmlns="http://www.w3.org/2000/svg">${s}</svg>`;
}

/* Vertical (< md): nodes in a column, labels beside — full-size type on phones. */
const VX = 26, VPAD = 40, VGAP = 84;
const H = VPAD * 2 + (n - 1) * VGAP;
const yOf = (i: number) => VPAD + i * VGAP;

function schematicV() {
  let s = '';
  for (let i = 0; i < n - 1; i++) s += link(VX, yOf(i), VX, yOf(i + 1), i >= 1);
  for (let i = 0; i < n - 1; i++) {
    s += pulse(VX, yOf(i), VX, yOf(i + 1), -0.55 * i - 0.4, i % 2 ? C.cyan2 : C.cyan, i % 2 ? 3.4 : 4);
  }
  for (let i = 0; i < n; i++) s += node(VX, yOf(i), !!stages[i]?.lit);
  for (let i = 0; i < n; i++) {
    const y = yOf(i);
    if (stages[i].note) {
      s += tag(VX + 28, y - 2, esc(stages[i].name), 'start');
      s += sub(VX + 28, y + 15, esc(stages[i].note!), 'start');
    } else {
      s += tag(VX + 28, y + 5, esc(stages[i].name), 'start');
    }
  }
  return `<svg viewBox="0 0 340 ${H}" xmlns="http://www.w3.org/2000/svg">${s}</svg>`;
}
---
<div class:list={['panel relative overflow-hidden p-6 sm:p-8', className]}>
  <div class="bg-grid pointer-events-none absolute inset-0 opacity-40"></div>
  {label && (
    <p class="mono-label relative flex items-center gap-2">
      <span class="status-dot"></span>
      {label}
    </p>
  )}
  {/* 40rem floor: the tightest md-viewport case is 768 − ~15px classic desktop
      scrollbar − 48 page px-6 − 64 card p-8 ≈ 641px, so the horizontal variant
      always fits ≥ md (max-w-3xl pages included); overflow-x-auto stays as
      belt-and-braces. Below md, the vertical stack — the wide SVG used to clip. */}
  <div class:list={['relative overflow-x-auto', label && 'mt-4']}>
    <div class="hidden min-w-[40rem] md:block" aria-hidden="true" set:html={schematic()}></div>
    <div class="mx-auto max-w-sm md:hidden" aria-hidden="true" set:html={schematicV()}></div>
  </div>
</div>
