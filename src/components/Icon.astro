---
/**
 * Icon.astro — resolves a Lucide icon by string name so the section registry
 * (src/data/sections.ts) can stay a plain serializable data file. Add a new
 * icon: import it and add one line to MAP.
 */
import {
  Home, GitBranch, Wrench, Timer, LayoutGrid, Network, PenLine,
  Newspaper, Bookmark, Radar, ArrowUpRight, ArrowRight, Hammer,
  UserRound, Lightbulb, FileText, BellRing, Briefcase,
  Layers, Compass, Zap, Webhook, Terminal, Menu, Smartphone,
  Search, Palette, Boxes, Link,
  Brain, Code, Globe, Database, Server, Shield, Cpu, GraduationCap,
  Sparkles, Podcast,
} from '@lucide/astro';

const MAP: Record<string, any> = {
  home: Home,
  'git-branch': GitBranch,
  wrench: Wrench,
  timer: Timer,
  'layout-grid': LayoutGrid,
  network: Network,
  'pen-line': PenLine,
  podcast: Podcast,
  newspaper: Newspaper,
  bookmark: Bookmark,
  radar: Radar,
  'arrow-up-right': ArrowUpRight,
  'arrow-right': ArrowRight,
  hammer: Hammer,
  'user-round': UserRound,
  lightbulb: Lightbulb,
  'file-text': FileText,
  'bell-ring': BellRing,
  briefcase: Briefcase,
  layers: Layers,
  compass: Compass,
  zap: Zap,
  webhook: Webhook,
  terminal: Terminal,
  menu: Menu,
  smartphone: Smartphone,
  search: Search,
  palette: Palette,
  boxes: Boxes,
  link: Link,
  brain: Brain,
  code: Code,
  globe: Globe,
  database: Database,
  server: Server,
  shield: Shield,
  cpu: Cpu,
  'graduation-cap': GraduationCap,
  sparkles: Sparkles,
};

interface Props {
  name: string;
  size?: number;
  class?: string;
  'stroke-width'?: number;
}

const { name, size = 20, class: className, ...rest } = Astro.props;
const Cmp = MAP[name] ?? Hammer;
// Brand marks Lucide dropped — rendered inline as single-path SVGs (viewBox 0 0 24 24, filled).
const BRAND: Record<string, string> = {
  linkedin: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.919-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z',
  nextdoor: 'M1.14 2.25C0.51 2.25 0 2.76 0 3.4L0 6.84C0 9.69 2.3 12 5.14 12L5.72 12L5.72 20.6C5.72 21.24 6.23 21.75 6.86 21.75L11.43 21.75C12.06 21.75 12.57 21.24 12.57 20.6L12.57 11.42C12.57 10.16 13.59 9.13 14.86 9.13C16.12 9.13 17.14 10.16 17.14 11.42L17.14 20.6C17.14 21.24 17.65 21.75 18.28 21.75L22.86 21.75C23.49 21.75 24 21.24 24 20.6L24 11.42C24 6.36 19.91 2.25 14.86 2.25C11.72 2.25 8.95 3.84 7.31 6.25C7.05 6.2 6.86 5.97 6.86 5.69L6.86 3.4C6.86 2.76 6.35 2.25 5.72 2.25ZM1.14 2.25',
};
---
{BRAND[name] ? (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
    <path d={BRAND[name]} />
  </svg>
) : (
  <Cmp size={size} class={className} {...rest} />
)}
