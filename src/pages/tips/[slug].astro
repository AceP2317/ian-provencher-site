---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import { site } from '../../data/site';
import {
  publishedFilter, tipSchema, formatEntryDate, isoDate, CATEGORY_META,
} from '../../data/tips';

export async function getStaticPaths() {
  const entries = await getCollection('tips', publishedFilter);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

interface Props { entry: CollectionEntry<'tips'>; }
const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
const meta = CATEGORY_META[data.category];
const origin = new URL(Astro.site!).origin;
---
<PageLayout
  title={data.title}
  description={data.description}
  image="/og/tips.png?v=1"
  ogType="article"
  article={{
    publishedTime: isoDate(data.publishedAt),
    modifiedTime: data.updatedAt ? isoDate(data.updatedAt) : undefined,
    author: site.author,
  }}
  schema={tipSchema(entry, origin)}
>
  <article class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
    <a href="/tips/" class="text-sm font-medium text-cyan-deep transition-colors hover:text-cyan">
      ← All tips
    </a>

    <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-2">
      <time datetime={isoDate(data.publishedAt)} class="font-mono text-xs tracking-wide text-ink-faint">
        {formatEntryDate(data.publishedAt)}
      </time>
      <span class="chip">
        <span class="chip-dot" style={`background:${meta.dot}`}></span>
        {meta.label}
      </span>
    </div>

    <h1 class="mt-4 font-display text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
      {data.title}
    </h1>
    <p class="mt-3 text-sm text-ink-faint">By {site.author}</p>

    <div class="post-prose mt-8">
      <Content />
    </div>

    {data.tags.length > 0 && (
      <div class="mt-10 flex flex-wrap gap-2 border-t border-line pt-6">
        {data.tags.map((t) => (
          <span class="rounded-full border border-line bg-surface-2 px-2.5 py-0.5 font-mono text-[0.65rem] text-ink-faint">#{t}</span>
        ))}
      </div>
    )}
  </article>
</PageLayout>
