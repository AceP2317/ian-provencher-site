---
/**
 * /stack/status-line — the seven-row status-line instrument. The script is a
 * PUBLIC gist already; the only scrub is not embedding a literal sample render
 * (a real cwd path would trip the safe-export gate), so the rows are described.
 */
import PageLayout from '../../layouts/PageLayout.astro';
import Icon from '../../components/Icon.astro';
import { statusRows, statusGistUrl } from '../../data/stack';

const origin = new URL(Astro.site!).origin;
const description =
  'A seven-row live status line for Claude Code — tokens, cache economics, spend, and rate limits at a glance, rendered in a single jq pass. Public on GitHub.';

const schema = [
  {
    '@type': 'BreadcrumbList',
    '@id': `${origin}/stack/status-line/#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${origin}/` },
      { '@type': 'ListItem', position: 2, name: 'Operating Stack', item: `${origin}/stack/` },
      { '@type': 'ListItem', position: 3, name: 'The status line', item: `${origin}/stack/status-line/` },
    ],
  },
];
---
<PageLayout title="The status line" description={description} image="/og/stack-status-line.png?v=1" schema={schema}>
  {/* Same grid backdrop the /stack hub hero carries — this page is in that family. */}
  <section class="relative overflow-hidden">
    <div class="bg-grid bg-grid-fade pointer-events-none absolute inset-0 -z-10 opacity-60"></div>
    <div class="relative mx-auto max-w-4xl px-6 pt-16 pb-6 sm:pt-20">
      <a href="/stack/" class="inline-flex items-center gap-1.5 text-sm text-ink-faint transition-colors hover:text-ink">
        <Icon name="arrow-right" size={14} class="rotate-180" /> Operating Stack
      </a>
      <p class="mono-label mt-6">The status line · Claude Code</p>
      <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl">
        A cockpit readout for every session.
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-muted">
        Claude Code lets you replace the status line with your own script. Mine is a seven-row
        instrument — location, conversation economics, tokens, cache, spend, billing cycle, and
        rate limits — each a bold color-coded tag, all parsed in a single <code class="font-mono text-sm text-cyan-deep">jq</code>
        pass so it stays fast even on Windows Git-Bash. A traffic-light helper colors each figure green,
        amber, or red; a formatter turns raw seconds into plain-English time-to-reset.
      </p>
    </div>
  </section>

  {/* ── The seven rows ─────────────────────────────────────────────────── */}
  <section class="mx-auto max-w-4xl px-6 pb-12">
    <div class="flex items-center gap-3">
      <h2 class="section-index">The seven rows</h2>
      <span class="h-px flex-1 bg-line"></span>
      <span class="font-mono text-xs text-ink-faint">{statusRows.length}</span>
    </div>
    {/* Cards, not table rows — each row of the instrument is a readout, so it gets its
        own panel with the row's own signal color on the dot and the tag. */}
    <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
      {statusRows.map((row) => (
        <div class="reveal panel flex flex-col gap-2 p-5">
          <div class="flex items-center gap-2.5">
            <span class="h-1.5 w-1.5 shrink-0 rounded-full" style={`background: var(--color-${row.accent})`}></span>
            <code class="font-mono text-sm font-semibold tracking-wide" style={`color: var(--color-${row.accent})`}>
              {row.tag}
            </code>
          </div>
          <span class="text-sm leading-relaxed text-ink-muted">{row.reads}</span>
        </div>
      ))}
    </div>
    <p class="mt-4 text-sm leading-relaxed text-ink-faint">
      The dollar figures are an API-equivalent usage gauge — what the same tokens would cost on the
      metered API — not a real subscription charge. It’s there to keep me honest about how much a
      given approach actually burns.
    </p>
  </section>

  {/* ── The gist ───────────────────────────────────────────────────────── */}
  <section class="section-band">
    <div class="mx-auto max-w-4xl px-6 py-14 sm:py-16">
      <p class="mono-label">Take it</p>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-muted">
        The whole script is public — one file, no dependencies beyond <code class="font-mono text-sm text-cyan-deep">jq</code>.
        A hook <a href="/stack/hooks/" class="text-cyan-deep hover:underline">auto-publishes it</a> every time I
        change it, so the gist is always the current build.
      </p>
      <div class="mt-6">
        <a href={statusGistUrl} target="_blank" rel="noopener" class="btn btn-primary text-sm">
          <Icon name="git-branch" size={15} /> View the gist on GitHub
        </a>
      </div>
    </div>
  </section>
</PageLayout>
