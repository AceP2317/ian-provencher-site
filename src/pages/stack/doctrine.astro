---
/**
 * /stack/doctrine — the operating doctrine, rendered as public paraphrases of the
 * behavioral clauses (src/data/stack.ts). SCRUBBED: no operator-context, no
 * private repo path, no employer terms.
 */
import PageLayout from '../../layouts/PageLayout.astro';
import Icon from '../../components/Icon.astro';
import { doctrineClauses, doctrineName, doctrineVersion } from '../../data/stack';

const origin = new URL(Astro.site!).origin;
const description =
  'The behavioral clauses I run the model against — versioned, and injected into every session so the discipline never has to be re-typed.';

const schema = [
  {
    '@type': 'BreadcrumbList',
    '@id': `${origin}/stack/doctrine/#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${origin}/` },
      { '@type': 'ListItem', position: 2, name: 'Operating Stack', item: `${origin}/stack/` },
      { '@type': 'ListItem', position: 3, name: 'Operating doctrine', item: `${origin}/stack/doctrine/` },
    ],
  },
];
---
<PageLayout title="Operating doctrine" description={description} image="/og/stack-doctrine.png?v=1" schema={schema}>
  <section class="mx-auto max-w-4xl px-6 pt-16 pb-6 sm:pt-20">
    <a href="/stack/" class="inline-flex items-center gap-1.5 text-sm text-ink-faint transition-colors hover:text-ink">
      <Icon name="arrow-right" size={14} class="rotate-180" /> Operating Stack
    </a>
    <p class="mono-label mt-6">Doctrine · <span class="font-mono text-cyan-deep">{doctrineName} {doctrineVersion}</span></p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl">
      How I direct AI
    </h1>
    <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-muted">
      A frontier model does what you point it at. This is what I point it at — an ordered
      set of behavioral clauses, refined over dozens of builds, that I keep in a private repo
      and inject into <a href="/stack/hooks/" class="text-cyan-deep hover:underline">every session automatically</a>.
      It’s the difference between a clever chat and a system that ships.
    </p>
  </section>

  <section class="mx-auto max-w-4xl px-6 pb-20">
    <ol class="mt-4 flex flex-col gap-4">
      {doctrineClauses.map((c, i) => (
        <li class="reveal panel flex gap-5 p-6">
          <span class="mono-label shrink-0 pt-1 text-cyan-deep">/ {String(i + 1).padStart(2, '0')}</span>
          <div>
            <h2 class="font-display text-lg font-semibold tracking-tight text-ink">{c.title}</h2>
            <p class="mt-2 leading-relaxed text-ink-muted">{c.body}</p>
          </div>
        </li>
      ))}
    </ol>
    <p class="mt-8 text-sm leading-relaxed text-ink-faint">
      Paraphrased for the public — the working doctrine is versioned in a private repo and
      carries operator-specific context that stays private. The clauses above are the load-bearing ones.
    </p>
  </section>
</PageLayout>
