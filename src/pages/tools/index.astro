---
import PageLayout from '../../layouts/PageLayout.astro';
import { toolsByKind, tools, STATUS_META } from '../../data/tools';
import { bySlug } from '../../data/sections';

const section = bySlug.get('tools')!;
const groups = toolsByKind();
---
<PageLayout title="Builds" description={section.description} image="/og/tools.png?v=1">
  <section class="section">
    <div class="mx-auto max-w-6xl px-6">
      <div class="max-w-2xl">
        <p class="mono-label">Builds · {tools.length}</p>
        <h1 class="mt-2 font-display text-4xl font-semibold tracking-tight text-ink">
          The software I've built and shipped
        </h1>
        <p class="mt-4 text-base leading-relaxed text-ink-muted">
          Full-stack applications and operational tools, designed and shipped end to end — drawn
          from my Command Center's registry, exported public-safe. Live ones link straight to the
          working thing.
        </p>
      </div>

      {groups.map((group) => (
        <div class="mt-12">
          <div class="flex items-center gap-3">
            <h2 class="section-index">{group.label}</h2>
            <span class="h-px flex-1 bg-line"></span>
            <span class="font-mono text-xs text-ink-faint">{group.items.length}</span>
          </div>
          <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
            {group.items.map((t) => (
              <div class="reveal panel flex flex-col gap-3 p-5">
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-display text-base font-semibold leading-snug tracking-tight text-ink">{t.name}</h3>
                  <span class="chip shrink-0" style={`border-color: color-mix(in oklab, ${STATUS_META[t.status].color} 40%, transparent)`}>
                    <span class="chip-dot" style={`background:${STATUS_META[t.status].color}`}></span>
                    {STATUS_META[t.status].label}
                  </span>
                </div>
                <p class="font-mono text-[0.7rem] leading-relaxed text-cyan-deep">{t.tech}</p>
                <p class="text-sm leading-relaxed text-ink-muted">{t.description}</p>
                {t.links.length > 0 && (
                  <div class="mt-auto flex flex-wrap gap-x-4 gap-y-1 pt-1">
                    {t.links.map((l) => (
                      <a href={l.href} class="inline-flex items-center gap-1 text-xs font-medium text-accent-2 transition-colors hover:text-accent">
                        {l.label} <span aria-hidden="true">↗</span>
                      </a>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</PageLayout>
