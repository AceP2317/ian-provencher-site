---
import PageLayout from '../../layouts/PageLayout.astro';
import PipelineFlow from '../../components/PipelineFlow.astro';
import { bySlug } from '../../data/sections';
import { jobs, applyUrl, scoreTone } from '../../data/jobs';
import { profileSummary } from '../../data/job-profile';

const section = bySlug.get('jobs')!;
---
<PageLayout title="Job Board" description={section.description} image="/og/jobs.png?v=1">
  <section class="section">
    <div class="mx-auto max-w-4xl px-6">
      <div class="max-w-2xl">
        <p class="mono-label">Job Board · {jobs.length}</p>
        <h1 class="mt-2 font-display text-4xl font-semibold tracking-tight text-ink">
          Roles worth a look
        </h1>
        <p class="mt-4 text-base leading-relaxed text-ink-muted">
          A pulled, scored shortlist — postings matched against what I actually want
          ({profileSummary.toLowerCase().replace(/\.$/, '')}), each with a fit score and a one-line
          why. Each card opens a web search for the role, so you land on the employer's own posting.
        </p>
      </div>

      {/* How the board fills — the aggregator pipeline as a living flow */}
      <div class="mt-8">
        <PipelineFlow
          label="How the board fills — unattended, on a schedule"
          stages={[
            { name: 'pull', note: 'many job feeds' },
            { name: 'dedupe', note: 'company + title' },
            { name: 'filter', note: 'my criteria' },
            { name: 'score', note: 'AI fit 0–100', lit: true },
            { name: 'gate', note: 'public-safe' },
            { name: 'board', note: 'top matches', lit: true },
          ]}
        />
      </div>

      {jobs.length === 0 ? (
        <div class="mt-10 panel p-8">
          <p class="mono-label text-ink-faint">No postings yet</p>
          <p class="mt-3 max-w-xl text-sm leading-relaxed text-ink-muted">
            The board fills when the scheduled fetch runs: a job-aggregator feed is pulled, filtered
            to my criteria, scored for fit, and the top matches are committed here. Until the feed is
            wired up, this stays intentionally empty — no filler, no fake listings.
          </p>
        </div>
      ) : (
        <div class="mt-10 flex flex-col gap-4">
          {jobs.map((j) => (
            <a href={applyUrl(j)} target="_blank" rel="noopener noreferrer"
              class="reveal panel group flex flex-col gap-3 p-5 transition-colors duration-200 hover:border-line-2">
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <h2 class="font-display text-lg font-semibold leading-snug tracking-tight text-ink group-hover:text-accent-2">
                    {j.title}
                  </h2>
                  <p class="mt-1 text-sm text-ink-muted">
                    {j.company}<span class="text-ink-faint"> · {j.location}</span>
                  </p>
                </div>
                <span class="shrink-0 rounded-lg border border-line bg-surface-2 px-2.5 py-1 font-mono text-xs" style={`color:${scoreTone(j.score)}`}>
                  {j.score}<span class="text-ink-faint">/100</span>
                </span>
              </div>
              <p class="text-sm leading-relaxed text-ink-muted">{j.why}</p>
              <div class="mt-auto flex flex-wrap items-center justify-between gap-2 pt-1">
                <div class="flex flex-wrap items-center gap-2 text-xs text-ink-faint">
                  {j.salary && <span class="font-mono">{j.salary}</span>}
                  {j.flags.slice(0, 3).map((f) => (
                    <span class="rounded-full border border-line bg-surface-2 px-2 py-0.5 font-mono text-[0.6rem]">{f}</span>
                  ))}
                  <span class="font-mono">{j.source}</span>
                </div>
                <span class="shrink-0 text-xs font-medium text-cyan-deep group-hover:text-cyan">Find role ↗</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</PageLayout>
