---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import { site } from '../../data/site';
import {
  publishedFilter, sortByPublished, postSchema, formatEntryDate, isoDate, readingMinutes, SOURCE_META,
} from '../../data/blog';

type Neighbor = { id: string; title: string } | null;

export async function getStaticPaths() {
  const entries = (await getCollection('blog', publishedFilter)).sort(sortByPublished);
  return entries.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      // Newest-first order: the previous index is the newer post, next is older.
      newer: entries[i - 1] ? { id: entries[i - 1].id, title: entries[i - 1].data.title } : null,
      older: entries[i + 1] ? { id: entries[i + 1].id, title: entries[i + 1].data.title } : null,
    },
  }));
}

interface Props { entry: CollectionEntry<'blog'>; newer: Neighbor; older: Neighbor; }
const { entry, newer, older } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
const meta = SOURCE_META[data.source];
const origin = new URL(Astro.site!).origin;
const mins = readingMinutes(entry.body);
---
<PageLayout
  title={data.title}
  description={data.description}
  image={data.hero?.src}
  ogType="article"
  article={{
    publishedTime: isoDate(data.publishedAt),
    modifiedTime: data.updatedAt ? isoDate(data.updatedAt) : undefined,
    author: site.author,
  }}
  schema={postSchema(entry, origin)}
  rssHref="/blog/rss.xml"
>
  <article class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
    <a href="/blog/" class="text-sm font-medium text-cyan-deep transition-colors hover:text-cyan">
      ← All field notes
    </a>

    <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-2">
      <time datetime={isoDate(data.publishedAt)} class="font-mono text-xs tracking-wide text-ink-faint">
        {formatEntryDate(data.publishedAt)}
      </time>
      <span class="chip">
        <span class="chip-dot" style={`background:${meta.dot}`}></span>
        {meta.label}
      </span>
      <span class="font-mono text-xs tracking-wide text-ink-faint">{mins} min read</span>
      {data.updatedAt && (
        <span class="font-mono text-xs tracking-wide text-ink-faint">
          Updated {formatEntryDate(data.updatedAt)}
        </span>
      )}
    </div>

    <h1 class="mt-4 font-display text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
      {data.title}
    </h1>
    <p class="mt-3 text-sm text-ink-faint">By {site.author}</p>

    {data.source !== 'authored' && data.sourceUrl && (
      <p class="mt-4 text-sm text-ink-muted">
        Originally posted on {meta.label} —
        <a href={data.sourceUrl} class="text-cyan-deep hover:text-cyan">view the original ↗</a>
      </p>
    )}

    <div class="post-prose mt-8">
      <Content />
    </div>

    {data.tags.length > 0 && (
      <div class="mt-10 flex flex-wrap gap-2 border-t border-line pt-6">
        {data.tags.map((t) => (
          <span class="rounded-full border border-line bg-surface-2 px-2.5 py-0.5 font-mono text-[0.65rem] text-ink-faint">#{t}</span>
        ))}
      </div>
    )}

    {(newer || older) && (
      <nav class="mt-10 flex flex-col gap-4 border-t border-line pt-6 sm:flex-row sm:justify-between" aria-label="More field notes">
        {older ? (
          <a href={`/blog/${older.id}/`} class="group max-w-[48%]">
            <span class="mono-label text-ink-faint">← Older</span>
            <span class="mt-1 block text-sm font-medium text-cyan-deep transition-colors group-hover:text-cyan">{older.title}</span>
          </a>
        ) : <span></span>}
        {newer ? (
          <a href={`/blog/${newer.id}/`} class="group max-w-[48%] sm:text-right">
            <span class="mono-label text-ink-faint">Newer →</span>
            <span class="mt-1 block text-sm font-medium text-cyan-deep transition-colors group-hover:text-cyan">{newer.title}</span>
          </a>
        ) : <span></span>}
      </nav>
    )}
  </article>
</PageLayout>
