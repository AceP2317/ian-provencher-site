---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import Icon from '../../components/Icon.astro';
import { bySlug } from '../../data/sections';
import { favoritesByCategory, hostOf } from '../../data/favorites';

const section = bySlug.get('favorites')!;
const all = await getCollection('favorites');
const groups = favoritesByCategory(all);

// Curated tag chips = the most common tags (the tag vocabulary is a long tail,
// so top-N, not all). Built from the data so it stays accurate as favorites grow.
const tagCounts = new Map<string, number>();
for (const f of all) for (const t of f.data.tags ?? []) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 14)
  .map(([t]) => t);

const haystack = (f: (typeof all)[number]) =>
  `${f.data.title} ${hostOf(f.data.url)} ${f.data.description ?? ''} ${(f.data.tags ?? []).join(' ')}`.toLowerCase();
---
<PageLayout title="Favorites" description={section.description} image="/og/favorites.png?v=1">
  <section class="section">
    <div class="mx-auto max-w-6xl px-6" data-fav-board>
      <div class="max-w-2xl">
        <p class="mono-label">Favorites · <span data-fav-total>{all.length}</span></p>
        <h1 class="mt-2 font-display text-4xl font-semibold tracking-tight text-ink">
          A visual bookmarks board
        </h1>
        <p class="mt-4 text-base leading-relaxed text-ink-muted">
          The links I reach for, grouped the way I actually think about them — not a flat
          list buried in a browser menu.
        </p>
      </div>

      {/* Filter bar — text + category chips + curated tag chips (progressive: works only with JS). */}
      <div class="mt-8" data-fav-filter>
        <div class="flex max-w-xl items-center gap-2 rounded-lg border border-line bg-surface px-3 py-2 focus-within:border-line-2">
          <Icon name="search" size={16} class="shrink-0 text-ink-faint" />
          <input
            type="search"
            data-fav-input
            aria-label="Filter favorites"
            placeholder={`Filter ${all.length} links…`}
            autocomplete="off"
            class="min-w-0 flex-1 bg-transparent text-sm text-ink placeholder:text-ink-faint focus:outline-none"
          />
        </div>

        <div class="mt-4 flex flex-wrap items-center gap-2">
          <button type="button" data-fav-cat="all" aria-pressed="true" class="nav-chip">
            <span>All</span>
          </button>
          {groups.map((g) => (
            <button
              type="button"
              data-fav-cat={g.category}
              aria-pressed="false"
              class="nav-chip"
              style={`--chip-accent: ${g.meta.accent}`}
            >
              <span class="chip-icon"><Icon name={g.meta.icon} size={14} /></span>
              <span>{g.meta.label}</span>
            </button>
          ))}
        </div>

        <div class="mt-3 flex flex-wrap items-center gap-2">
          <span class="mono-label mr-1 text-ink-faint">Tags</span>
          {topTags.map((t) => (
            <button type="button" data-fav-tag={t} aria-pressed="false" class="chip">{t}</button>
          ))}
          <button type="button" data-fav-clear class="btn btn-secondary ml-1 hidden px-2.5 py-1 text-xs">
            Clear filters
          </button>
        </div>
      </div>

      <p data-fav-empty class="mt-10 hidden text-sm text-ink-muted">
        No favorites match your filter.
        <button type="button" data-fav-clear class="text-cyan-deep hover:text-cyan">Clear filters →</button>
      </p>
      {/* SR announcement for filter results — mirrors SearchOverlay's liveMsg pattern. */}
      <p data-fav-live aria-live="polite" class="sr-only"></p>

      {groups.map((g) => (
        <div class="mt-12" data-fav-group={g.category}>
          <div class="flex items-center gap-3">
            <span class="grid h-8 w-8 place-items-center rounded-lg border border-line bg-surface-2" style={`color:${g.meta.accent}`}>
              <Icon name={g.meta.icon} size={16} />
            </span>
            <h2 class="font-display text-lg font-semibold tracking-tight text-ink">{g.meta.label}</h2>
            <span class="h-px flex-1 bg-line"></span>
            <span class="font-mono text-xs text-ink-faint" data-fav-count>{g.items.length}</span>
          </div>
          <div class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {g.items.map((f) => (
              <a href={f.data.url}
                data-fav-card
                data-cat={f.data.category}
                data-tags={(f.data.tags ?? []).join('|')}
                data-search={haystack(f)}
                class="reveal panel group flex items-start gap-3 p-4 transition-colors duration-200 hover:border-line-2">
                <span class="mt-0.5 grid h-9 w-9 shrink-0 place-items-center rounded-lg border border-line bg-surface-2 font-display text-sm font-semibold"
                  style={`color:${g.meta.accent}`}>
                  {f.data.title.slice(0, 1)}
                </span>
                <div class="min-w-0">
                  <h3 class="truncate font-display text-sm font-semibold tracking-tight text-ink group-hover:text-accent-2">
                    {f.data.title}
                  </h3>
                  <p class="truncate font-mono text-[0.6rem] text-ink-faint">{hostOf(f.data.url)}</p>
                  {f.data.description && (
                    <p class="mt-1.5 text-xs leading-relaxed text-ink-muted">{f.data.description}</p>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* Client-side board filter: text + category chips + tag chips. Progressive — the
      full board is server-rendered; this only narrows what's already there. */}
  <script is:inline>
  (() => {
    const root = document.querySelector('[data-fav-filter]');
    if (!root) return;
    const board = document.querySelector('[data-fav-board]');
    const input = root.querySelector('[data-fav-input]');
    const catBtns = [...root.querySelectorAll('[data-fav-cat]')];
    const tagBtns = [...root.querySelectorAll('[data-fav-tag]')];
    const clearBtns = [...document.querySelectorAll('[data-fav-clear]')];
    const groups = [...document.querySelectorAll('[data-fav-group]')];
    const totalEl = document.querySelector('[data-fav-total]');
    const emptyEl = document.querySelector('[data-fav-empty]');
    const liveEl = document.querySelector('[data-fav-live]');

    const selCats = new Set();
    const selTags = new Set();
    let q = '';

    const apply = () => {
      const hasFilter = q !== '' || selCats.size > 0 || selTags.size > 0;
      board && board.classList.toggle('fav-filtering', hasFilter);

      let total = 0;
      for (const g of groups) {
        let visible = 0;
        for (const card of g.querySelectorAll('[data-fav-card]')) {
          const cardCat = card.getAttribute('data-cat');
          const cardTags = (card.getAttribute('data-tags') || '').split('|').filter(Boolean);
          const hay = card.getAttribute('data-search') || '';
          const show =
            (!q || hay.includes(q)) &&
            (selCats.size === 0 || selCats.has(cardCat)) &&
            (selTags.size === 0 || cardTags.some((t) => selTags.has(t)));
          card.style.display = show ? '' : 'none';
          if (show) visible++;
        }
        const countEl = g.querySelector('[data-fav-count]');
        if (countEl) countEl.textContent = String(visible);
        g.style.display = visible ? '' : 'none';
        total += visible;
      }
      if (totalEl) totalEl.textContent = String(total);
      if (emptyEl) emptyEl.classList.toggle('hidden', total > 0);
      if (liveEl) liveEl.textContent = total > 0 ? `${total} favorites shown` : 'No favorites match your filter';
      for (const b of clearBtns) b.classList.toggle('hidden', !hasFilter);
    };

    input &&
      input.addEventListener('input', () => {
        q = input.value.trim().toLowerCase();
        apply();
      });

    for (const btn of catBtns) {
      btn.addEventListener('click', () => {
        const cat = btn.getAttribute('data-fav-cat');
        if (cat === 'all') selCats.clear();
        else if (selCats.has(cat)) selCats.delete(cat);
        else selCats.add(cat);
        for (const b of catBtns) {
          const c = b.getAttribute('data-fav-cat');
          const on = c === 'all' ? selCats.size === 0 : selCats.has(c);
          b.setAttribute('aria-pressed', on ? 'true' : 'false');
        }
        apply();
      });
    }

    for (const btn of tagBtns) {
      btn.addEventListener('click', () => {
        const tag = btn.getAttribute('data-fav-tag');
        if (selTags.has(tag)) selTags.delete(tag);
        else selTags.add(tag);
        btn.setAttribute('aria-pressed', selTags.has(tag) ? 'true' : 'false');
        apply();
      });
    }

    const clearAll = () => {
      q = '';
      if (input) input.value = '';
      selCats.clear();
      selTags.clear();
      for (const b of catBtns) b.setAttribute('aria-pressed', b.getAttribute('data-fav-cat') === 'all' ? 'true' : 'false');
      for (const b of tagBtns) b.setAttribute('aria-pressed', 'false');
      apply();
    };
    for (const b of clearBtns) b.addEventListener('click', clearAll);
  })();
  </script>
</PageLayout>
