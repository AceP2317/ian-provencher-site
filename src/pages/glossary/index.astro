---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import Icon from '../../components/Icon.astro';
import { bySlug } from '../../data/sections';
import { glossaryByCategory, mergeGlossary, CATEGORY_META } from '../../data/glossary';
import { learnTopics } from '../../data/learn';

const section = bySlug.get('glossary')!;

// Bulk JSON base + any terms authored through the admin console (content collection).
const additions = (await getCollection('glossary')).map((e) => e.data);
const terms = mergeGlossary(additions);
const groups = glossaryByCategory(terms);
const total = terms.length;

// Cross-link each category header to the first Learn topic in that field (if any).
const learnByCat = new Map<string, string>();
for (const t of learnTopics) if (!learnByCat.has(t.category)) learnByCat.set(t.category, t.slug);

// Curated tag chips = the most common tags (the vocabulary is a long tail, so
// top-N, built from the data so it stays accurate as terms grow).
const tagCounts = new Map<string, number>();
for (const t of terms) for (const tag of t.tags) tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 16)
  .map(([t]) => t);

// JSON-LD: a DefinedTermSet is the schema.org type for a glossary.
const schema = [
  {
    '@type': 'DefinedTermSet',
    name: 'Technical Glossary — ian-provencher.com',
    description: section.description,
    url: 'https://ian-provencher.com/glossary/',
    hasDefinedTerm: terms.slice(0, 400).map((t) => ({
      '@type': 'DefinedTerm',
      name: t.term,
      description: t.definition,
      inDefinedTermSet: 'https://ian-provencher.com/glossary/',
    })),
  },
];
---
<PageLayout title="Glossary" description={section.description} image="/og/glossary.png?v=1" schema={schema}>
  <section class="section">
    <div class="mx-auto max-w-6xl px-6" data-gl-board>
      <div class="max-w-2xl">
        <p class="mono-label">Glossary · <span data-gl-total>{total}</span> terms</p>
        <h1 class="mt-2 font-display text-4xl font-semibold tracking-tight text-ink">
          A working technical dictionary
        </h1>
        <p class="mt-4 text-base leading-relaxed text-ink-muted">
          The vocabulary of the work — AI, software, the web, data, infrastructure, security,
          systems, and supply chain — defined plainly and grouped the way I actually reach for
          it. Filter by text, category, or tag.
        </p>
      </div>

      {/* Filter bar — text + category chips + curated tag chips (progressive: needs JS). */}
      <div class="mt-8" data-gl-filter>
        <div class="flex max-w-xl items-center gap-2 rounded-lg border border-line bg-surface px-3 py-2 focus-within:border-line-2">
          <Icon name="search" size={16} class="shrink-0 text-ink-faint" />
          <input
            type="search"
            data-gl-input
            aria-label="Filter glossary terms"
            placeholder={`Search ${total} terms…`}
            autocomplete="off"
            class="min-w-0 flex-1 bg-transparent text-sm text-ink placeholder:text-ink-faint focus:outline-none"
          />
        </div>

        <div class="mt-4 flex flex-wrap items-center gap-2">
          <button type="button" data-gl-cat="all" aria-pressed="true" class="nav-chip">
            <span>All</span>
          </button>
          {groups.map((g) => (
            <button
              type="button"
              data-gl-cat={g.category}
              aria-pressed="false"
              class="nav-chip"
              style={`--chip-accent: ${g.meta.accent}`}
            >
              <span class="chip-icon"><Icon name={g.meta.icon} size={14} /></span>
              <span>{g.meta.label}</span>
            </button>
          ))}
        </div>

        <div class="mt-3 flex flex-wrap items-center gap-2">
          <span class="mono-label mr-1 text-ink-faint">Tags</span>
          {topTags.map((t) => (
            <button type="button" data-gl-tag={t} aria-pressed="false" class="chip">{t}</button>
          ))}
          <button type="button" data-gl-clear class="btn btn-secondary ml-1 hidden px-2.5 py-1 text-xs">
            Clear filters
          </button>
        </div>
      </div>

      <p data-gl-empty class="mt-10 hidden text-sm text-ink-muted">
        No terms match your filter.
        <button type="button" data-gl-clear class="text-cyan-deep hover:text-cyan">Clear filters →</button>
      </p>
      {/* SR announcement for filter results — mirrors SearchOverlay's liveMsg pattern. */}
      <p data-gl-live aria-live="polite" class="sr-only"></p>

      {groups.map((g) => (
        <div class="mt-12" data-gl-group={g.category}>
          <div class="flex items-center gap-3">
            <span class="grid h-8 w-8 place-items-center rounded-lg border border-line bg-surface-2" style={`color:${g.meta.accent}`}>
              <Icon name={g.meta.icon} size={16} />
            </span>
            <h2 class="font-display text-lg font-semibold tracking-tight text-ink">{g.meta.label}</h2>
            {learnByCat.has(g.category) && (
              <a href={`/learn/#${learnByCat.get(g.category)}`} class="hidden shrink-0 font-mono text-[0.65rem] uppercase tracking-wider text-ink-faint transition-colors hover:text-accent-2 sm:inline">
                Learn this field →
              </a>
            )}
            <span class="h-px flex-1 bg-line"></span>
            <span class="font-mono text-xs text-ink-faint" data-gl-count>{g.items.length}</span>
          </div>
          <div class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2">
            {g.items.map((t) => (
              <div
                id={t.slug}
                data-gl-card
                data-cat={t.category}
                data-tags={t.tags.join('|')}
                class="group relative panel scroll-mt-24 overflow-hidden p-4 pl-5 transition-colors hover:border-line-2"
              >
                <span class="absolute inset-y-0 left-0 w-1" style={`background:${g.meta.accent}`} aria-hidden="true"></span>
                <div class="flex items-baseline justify-between gap-3">
                  <h3 class="font-display text-sm font-semibold tracking-tight text-ink transition-colors group-hover:text-accent-2">{t.term}</h3>
                  <div class="flex shrink-0 items-center gap-2">
                    {t.aliases.length > 0 && (
                      <span class="font-mono text-[0.6rem] text-ink-faint">{t.aliases.join(' · ')}</span>
                    )}
                    <button
                      type="button"
                      data-gl-copy={t.slug}
                      title="Copy link to this term"
                      aria-label={`Copy link to ${t.term}`}
                      class="text-ink-faint opacity-0 transition-opacity hover:text-accent-2 focus-visible:opacity-100 group-hover:opacity-100"
                    >
                      <Icon name="link" size={12} />
                    </button>
                  </div>
                </div>
                <p class="mt-1.5 text-xs leading-relaxed text-ink-muted">{t.definition}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
    <div data-gl-toast class="pointer-events-none fixed bottom-6 left-1/2 z-50 -translate-x-1/2 rounded-lg border border-line-2 bg-surface-2 px-3 py-1.5 text-xs text-ink opacity-0 shadow-lg transition-opacity">
      Link copied
    </div>
  </section>

  {/* Client-side filter: text + category chips + tag chips. Progressive — the full
      list is server-rendered; this only narrows what's already there. */}
  <script is:inline>
  (() => {
    const root = document.querySelector('[data-gl-filter]');
    if (!root) return;
    const input = root.querySelector('[data-gl-input]');
    const catBtns = [...root.querySelectorAll('[data-gl-cat]')];
    const tagBtns = [...root.querySelectorAll('[data-gl-tag]')];
    const clearBtns = [...document.querySelectorAll('[data-gl-clear]')];
    const groups = [...document.querySelectorAll('[data-gl-group]')];
    const totalEl = document.querySelector('[data-gl-total]');
    const emptyEl = document.querySelector('[data-gl-empty]');
    const liveEl = document.querySelector('[data-gl-live]');

    const selCats = new Set();
    const selTags = new Set();
    let q = '';

    // Build a card's search haystack from its own rendered text (+ tags) lazily,
    // cached on the node — cheaper than shipping a duplicate data-search per card.
    const hayOf = (card) => {
      if (card._hay === undefined) {
        const tags = (card.getAttribute('data-tags') || '').replace(/\|/g, ' ');
        card._hay = (card.textContent + ' ' + tags).toLowerCase();
      }
      return card._hay;
    };

    const apply = () => {
      const hasFilter = q !== '' || selCats.size > 0 || selTags.size > 0;
      let total = 0;
      for (const g of groups) {
        let visible = 0;
        for (const card of g.querySelectorAll('[data-gl-card]')) {
          const cardCat = card.getAttribute('data-cat');
          const cardTags = (card.getAttribute('data-tags') || '').split('|').filter(Boolean);
          const hay = q ? hayOf(card) : '';
          const show =
            (!q || hay.includes(q)) &&
            (selCats.size === 0 || selCats.has(cardCat)) &&
            (selTags.size === 0 || cardTags.some((t) => selTags.has(t)));
          card.style.display = show ? '' : 'none';
          if (show) visible++;
        }
        const countEl = g.querySelector('[data-gl-count]');
        if (countEl) countEl.textContent = String(visible);
        g.style.display = visible ? '' : 'none';
        total += visible;
      }
      if (totalEl) totalEl.textContent = String(total);
      if (emptyEl) emptyEl.classList.toggle('hidden', total > 0);
      if (liveEl) liveEl.textContent = total > 0 ? `${total} terms shown` : 'No terms match your filter';
      for (const b of clearBtns) b.classList.toggle('hidden', !hasFilter);
    };

    // Debounced — the display-toggle loop runs over every card, so don't fire per keystroke.
    let t = 0;
    input &&
      input.addEventListener('input', () => {
        clearTimeout(t);
        t = setTimeout(() => {
          q = input.value.trim().toLowerCase();
          apply();
        }, 120);
      });

    for (const btn of catBtns) {
      btn.addEventListener('click', () => {
        const cat = btn.getAttribute('data-gl-cat');
        if (cat === 'all') selCats.clear();
        else if (selCats.has(cat)) selCats.delete(cat);
        else selCats.add(cat);
        for (const b of catBtns) {
          const c = b.getAttribute('data-gl-cat');
          const on = c === 'all' ? selCats.size === 0 : selCats.has(c);
          b.setAttribute('aria-pressed', on ? 'true' : 'false');
        }
        apply();
      });
    }

    for (const btn of tagBtns) {
      btn.addEventListener('click', () => {
        const tag = btn.getAttribute('data-gl-tag');
        if (selTags.has(tag)) selTags.delete(tag);
        else selTags.add(tag);
        btn.setAttribute('aria-pressed', selTags.has(tag) ? 'true' : 'false');
        apply();
      });
    }

    const clearAll = () => {
      q = '';
      if (input) input.value = '';
      selCats.clear();
      selTags.clear();
      for (const b of catBtns) b.setAttribute('aria-pressed', b.getAttribute('data-gl-cat') === 'all' ? 'true' : 'false');
      for (const b of tagBtns) b.setAttribute('aria-pressed', 'false');
      apply();
    };
    for (const b of clearBtns) b.addEventListener('click', clearAll);

    // Copy a deep-link to a term. Delegated, and bound EXACTLY ONCE.
    //
    // This script re-executes on every view transition and `document` survives the swap, so
    // an unguarded listener here would accumulate: leave and return to /glossary three times
    // and one click would write the clipboard three times and fire three toasts.
    //
    // The toast element is also resolved at CLICK time rather than captured at bind time —
    // a captured reference would point at the previous page's now-detached node, and the
    // toast would silently stop appearing.
    if (!window.__ipGlossaryCopy) {
      window.__ipGlossaryCopy = true;
      let toastT = 0;
      document.addEventListener('click', (e) => {
        const btn = e.target instanceof Element ? e.target.closest('[data-gl-copy]') : null;
        if (!btn) return;
        const toast = document.querySelector('[data-gl-toast]');
        const slug = btn.getAttribute('data-gl-copy');
        const url = `${location.origin}/glossary/#${slug}`;
        const done = () => {
          if (!toast) return;
          toast.style.opacity = '1';
          clearTimeout(toastT);
          toastT = setTimeout(() => (toast.style.opacity = '0'), 1400);
        };
        if (navigator.clipboard?.writeText) navigator.clipboard.writeText(url).then(done, done);
        else done();
      });
    }
  })();
  </script>
</PageLayout>
