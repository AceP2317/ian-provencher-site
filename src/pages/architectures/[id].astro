---
import PageLayout from '../../layouts/PageLayout.astro';
import ArchitectureViewer from '../../components/islands/ArchitectureViewer.jsx';
import { architectures, archSlug, archSchema } from '../../data/architectures';

export function getStaticPaths() {
  return architectures.map((arch) => ({
    params: { id: archSlug(arch.id) },
    props: { arch },
  }));
}

const { arch } = Astro.props;
const origin = new URL(Astro.site!).origin;
// D10: og:image needs a `?v=N` cache-bust — bump this literal by hand whenever
// gen-assets.mjs regenerates this arch's card (see BaseLayout.astro:45-46).
const ogImage = `/og/${arch.id}.png?v=1`;
---
<PageLayout
  title={arch.title}
  description={arch.tagline}
  image={ogImage}
  schema={archSchema(arch, origin)}
>
  <section class="section">
    <div class="mx-auto max-w-6xl px-6">
      <a href="/architectures/" class="mono-label transition-colors hover:text-ink">← All architectures</a>
      <h1 class="mt-3 max-w-3xl font-display text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
        {arch.title}
      </h1>
      <p class="mt-3 max-w-2xl text-base leading-relaxed text-ink-muted">{arch.tagline}</p>

      <div class="mt-8">
        <ArchitectureViewer arch={arch} client:visible />
      </div>
    </div>
  </section>
</PageLayout>
