---
import PageLayout from '../../layouts/PageLayout.astro';
import Icon from '../../components/Icon.astro';
import PipelineFlow from '../../components/PipelineFlow.astro';
import { bySlug } from '../../data/sections';
import { tools } from '../../data/tools';
import { architectures } from '../../data/architectures';

const section = bySlug.get('command-center')!;

const principles = [
  { icon: 'network', title: 'Local-first', body: 'No database — the truth is plain JSON files, one per record. Anything that can read files can read (and audit) the whole operation.' },
  { icon: 'radar', title: 'Live', body: 'A file watcher pushes changes to the browser over SSE. The screen moves the instant either the UI or an agent touches anything.' },
  { icon: 'timer', title: 'Self-briefing', body: 'A nightly headless agent sweeps every source and writes the morning briefing before I am awake — current without being tended.' },
  { icon: 'git-branch', title: 'Human-gated', body: 'Agents dispatch, claim, and finish work — but only I move it to done. That gate is enforced in code, not convention.' },
];

const modules = [
  { name: 'dashboard', desc: 'the at-a-glance state of the whole operation' },
  { name: 'projects', desc: 'the ventures and builds in motion' },
  { name: 'task board', desc: 'the kanban of what moves each forward' },
  { name: 'assignments', desc: 'work dispatched to agents — RUN NOW fires a headless agent with a per-assignment model + effort (inbox → active → review → done)' },
  { name: 'skill library', desc: 'the house skills, versioned and synced to every AI surface' },
  { name: 'tool registry', desc: 'the registry behind the Tools page' },
  { name: 'architectures', desc: 'the diagrams behind the Architectures page' },
  { name: 'goals / horizon', desc: 'now / this-year / multi-year' },
  { name: 'learning', desc: 'what I am actively getting fluent in' },
  { name: 'knowledge', desc: 'an index into the vault' },
  { name: 'briefings', desc: 'the nightly self-written summaries' },
  { name: 'brain', desc: 'a sanitized graph of the vault — 803 notes, 1,871 links' },
  { name: 'ops log', desc: 'the running record of what the machinery did' },
  { name: 'the bridge', desc: 'live gauges, a module constellation, and real-time SSE readouts' },
];
---
<PageLayout title="Command Center" description={section.description} image="/og/command-center.png?v=1">
  <section class="section">
    <div class="mx-auto max-w-5xl px-6">
      <div class="max-w-2xl">
        <p class="mono-label">Command Center · the ops console</p>
        <h1 class="mt-2 font-display text-4xl font-semibold tracking-tight text-ink">
          The console I run everything from
        </h1>
        <p class="mt-4 font-display text-lg leading-relaxed text-cyan">
          The console is the bridge; Claude Code is the engine room.
        </p>
        <p class="mt-4 text-base leading-relaxed text-ink-muted">
          A local-first operations console where the UI and the AI work the same files.
          It has grown to a dozen-plus modules — projects, a task board, agent assignments
          with live headless dispatch, tools, architectures, a sanitized vault graph, an ops
          log, and a real-time "Bridge" of gauges — the source that several sections of this
          very site are exported from. It installs as a PWA on the desktop and rides in a
          native app on my phone.
        </p>
      </div>

      {/* Principles */}
      <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2">
        {principles.map((p) => (
          <div class="reveal panel flex gap-4 p-5">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-lg border border-line bg-surface-2 text-cyan">
              <Icon name={p.icon} size={19} />
            </span>
            <div>
              <h2 class="font-display text-base font-semibold tracking-tight text-ink">{p.title}</h2>
              <p class="mt-1 text-sm leading-relaxed text-ink-muted">{p.body}</p>
            </div>
          </div>
        ))}
      </div>

      {/* Collections */}
      <div class="mt-12">
        <div class="flex items-center gap-3">
          <h2 class="section-index">The modules</h2>
          <span class="h-px flex-1 bg-line"></span>
        </div>
        <div class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2">
          {modules.map((c) => (
            <div class="reveal flex items-baseline gap-3 rounded-lg border border-line bg-surface/50 px-4 py-3">
              <code class="font-mono text-xs text-cyan-deep">{c.name}</code>
              <span class="text-sm text-ink-muted">— {c.desc}</span>
            </div>
          ))}
        </div>
      </div>

      {/* Tie-in / safety */}
      <div class="mt-12 panel bg-surface/40 p-6">
        <p class="mono-label">How it ties in here</p>
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-ink-muted">
          This public site never connects to the command center live — it's gated and
          private by design. Instead, a reviewed <span class="font-mono text-xs text-cyan-deep">public-safe snapshot</span>
          is exported from it: the {tools.length} builds and {architectures.length} architectures you can
          browse here were published through an opt-in gate that strips anything sensitive
          before it ever reaches the web.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="/architectures/command-center/" class="btn btn-primary text-sm">
            <Icon name="network" size={15} /> See the architecture
          </a>
          <a href="/tools/" class="btn btn-secondary text-sm">Browse the builds</a>
        </div>
      </div>

      {/* The safe-export pipeline as a living flow */}
      <div class="mt-6">
        <PipelineFlow
          label="The safe-export pipeline — private infrastructure → reviewed public snapshot"
          stages={[
            { name: 'source', note: 'private CCOS · Hermes' },
            { name: 'export', note: 'field allowlist' },
            { name: 'scrub', note: 'denylist' },
            { name: 'gate', note: 'never ships red', lit: true },
            { name: 'commit', note: 'reviewable diff' },
            { name: 'deploy', note: 'live in ~1 min', lit: true },
          ]}
        />
      </div>
    </div>
  </section>
</PageLayout>
