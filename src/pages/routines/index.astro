---
import PageLayout from '../../layouts/PageLayout.astro';
import Icon from '../../components/Icon.astro';
import { bySlug } from '../../data/sections';
import { routineGroups } from '../../data/routines';

const section = bySlug.get('routines')!;
const total = routineGroups.reduce((n, g) => n + g.items.length, 0);
---
<PageLayout title="Routines" description={section.description} image="/og/routines.png?v=1">
  <section class="section">
    <div class="mx-auto max-w-6xl px-6">
      <div class="max-w-2xl">
        <p class="mono-label">Routines · {total}</p>
        <h1 class="mt-2 font-display text-4xl font-semibold tracking-tight text-ink">
          The notifications that keep me in the loop
        </h1>
        <p class="mt-4 text-base leading-relaxed text-ink-muted">
          My systems run themselves — but they reach me when it matters. Here's what each routine
          watches, how it reaches my phone, and why it earns an interruption. The loop runs both
          ways: I can dispatch work back from the same phone.
        </p>
      </div>

      {/* House pattern (see /tools): group = header rule, item = card. Each card carries
          the same three-part readout the build cards do — name + channel chip, the mono
          trigger line, then what it watches. */}
      {routineGroups.map((g) => (
        <div class="mt-12">
          <div class="flex items-center gap-3">
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-lg border border-line bg-surface-2" style={`color:${g.accent}`}>
              <Icon name={g.icon} size={16} />
            </span>
            <h2 class="font-display text-lg font-semibold tracking-tight text-ink">{g.label}</h2>
            <span class="h-px flex-1 bg-line"></span>
            <span class="font-mono text-xs text-ink-faint">{g.items.length}</span>
          </div>

          {g.note && (
            <p class="mt-4 border-l-2 pl-3 text-xs italic leading-relaxed text-ink-muted" style={`border-color:${g.accent}`}>
              {g.note}
            </p>
          )}

          <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
            {g.items.map((r) => (
              <div class="reveal panel flex flex-col gap-3 p-5">
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-display text-base font-semibold leading-snug tracking-tight text-ink">{r.name}</h3>
                  <span class="chip shrink-0" style={`border-color: color-mix(in oklab, ${g.accent} 40%, transparent)`}>
                    <span class="chip-dot" style={`background:${g.accent}`}></span>
                    {r.channel}
                  </span>
                </div>
                <p class="font-mono text-[0.7rem] leading-relaxed text-cyan-deep">{r.trigger}</p>
                <p class="text-sm leading-relaxed text-ink-muted">{r.purpose}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</PageLayout>
